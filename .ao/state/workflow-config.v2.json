  "pipelines": [
    {
      "id": "standard",
      "name": "Standard (Custom)",
      "description": "Standard pipeline with review sub-pipeline",
      "phases": [
        "requirements",
        {
          "id": "implementation",
          "skip_if": [
            "task_type == docs"
          ]
        },
        {
          "pipeline": "review-cycle"
        }
      ]
    },
    {
      "id": "ui-ux-standard",
      "name": "UI UX Standard",
      "description": "Frontend-oriented flow with UX research, wireframes, and mockup review gates.",
      "phases": [
        "requirements",
        "ux-research",
        "wireframe",
        "mockup-review",
        "implementation",
        "code-review",
        "testing"
      ]
    },
    {
      "id": "review-cycle",
      "name": "Review Cycle",
      "description": "Reusable code review and testing sequence",
      "phases": [
        {
          "id": "code-review",
          "on_verdict": {
            "rework": {
              "target": "code-review"
            }
          }
        },
        "testing"
      ]
    },
    {
      "id": "quick-fix",
      "name": "Quick Fix",
      "description": "Fast pipeline for small bug fixes",
      "phases": [
        "implementation",
        "testing"
      ]
    },
    {
      "id": "gated",
      "name": "Gated",
      "description": "Full pipeline with requirements validation, implementation, deterministic test/lint gates, code review, and PO sign-off",
      "phases": [
        "requirements",
        "implementation",
        "unit-test",
        "lint",
        {
          "id": "code-review",
          "on_verdict": {
            "rework": {
              "target": "implementation"
            }
          }
        },
        "po-review"
      ]
    }
  ],
  "checkpoint_retention": {
    "keep_last_per_phase": 10,
    "max_age_hours": null,
    "auto_prune_on_completion": false
  },
  "phase_definitions": {
    "lint": {
      "mode": "command",
      "agent_id": null,
      "directive": "Run clippy with deny warnings",
      "runtime": null,
      "capabilities": null,
      "output_contract": null,
      "output_json_schema": null,
      "decision_contract": null,
      "retry": null,
      "command": {
        "program": "cargo",
        "args": [
          "clippy",
          "--workspace",
          "--",
          "-D",
          "warnings"
        ],
        "env": {},
        "cwd_mode": "project_root",
        "cwd_path": null,
        "timeout_secs": 120,
        "success_exit_codes": [
          0
        ],
        "parse_json_output": false,
        "expected_result_kind": null,
        "expected_schema": null
      },
      "manual": null
    },
    "po-review": {
      "mode": "manual",
      "agent_id": null,
      "directive": null,
      "runtime": null,
      "capabilities": null,
      "output_contract": null,
      "output_json_schema": null,
      "decision_contract": null,
      "retry": null,
      "command": null,
      "manual": {
        "instructions": "Review the completed task against all acceptance criteria.\nVerify:\n- All requirements from the task description are met\n- All checklist items are addressed\n- Tests pass and cover the new functionality\n- No regressions introduced\nApprove only if the task is fully complete and production-ready.\n",
        "approval_note_required": true
      }
    },
    "unit-test": {
      "mode": "command",
      "agent_id": null,
      "directive": "Run the workspace test suite",
      "runtime": null,
      "capabilities": null,
      "output_contract": null,
      "output_json_schema": null,
      "decision_contract": null,
      "retry": null,
      "command": {
        "program": "cargo",
        "args": [
          "test",
          "--workspace"
        ],
        "env": {},
        "cwd_mode": "project_root",
        "cwd_path": null,
        "timeout_secs": 600,
        "success_exit_codes": [
          0
        ],
        "parse_json_output": false,
        "expected_result_kind": null,
        "expected_schema": null
      },
      "manual": null
    }
  },
  "agent_profiles": {
    "po-reviewer": {
      "description": "",
      "system_prompt": "You are a Product Owner reviewing completed development work.\nYour job is to verify that ALL acceptance criteria and requirements\nfrom the original task are fully met by the implementation.\nYou must be thorough and check every requirement, not just a sample.\n",
      "role": null,
      "mcp_servers": {},
      "tool_policy": {
        "allow": [],
        "deny": []
      },
      "skills": [],
      "capabilities": {
        "code_execution": false
      },
      "tool": "claude",
      "model": "claude-sonnet-4-6",
      "fallback_models": [],
      "reasoning_effort": null,
      "web_search": null,
      "network_access": null,
      "timeout_secs": null,
      "max_attempts": null,
      "extra_args": [],
      "codex_config_overrides": []
