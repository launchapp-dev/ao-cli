  "phases": {
    "default": {
      "mode": "agent",
      "agent_id": "default",
      "directive": "Execute the current workflow phase with production-quality output.",
      "runtime": null,
      "output_contract": null,
      "output_json_schema": null,
      "command": null,
      "manual": null
    },
    "requirements": {
      "mode": "agent",
      "agent_id": "po",
      "directive": "Clarify implementation scope, constraints, and acceptance criteria. Update docs and implementation notes as needed.",
      "runtime": null,
      "output_contract": null,
      "output_json_schema": null,
      "decision_contract": {
        "required_evidence": [],
        "min_confidence": 0.6,
        "max_risk": "medium",
        "allow_missing_decision": true
      },
      "command": null,
      "manual": null
    },
    "research": {
      "mode": "agent",
      "agent_id": "default",
      "directive": "Gather external and codebase evidence needed to de-risk the next implementation step. Treat greenfield repositories as valid and provide assumptions/plan artifacts when source is sparse. Keep discovery targeted to first-party code and active requirement/task docs; avoid broad scans of dependency or workflow checkpoint directories. Only emit research_required for true external blockers.",
      "capabilities": {
        "is_research": true
      },
      "runtime": {
        "tool": null,
        "model": null,
        "fallback_models": [],
        "reasoning_effort": null,
        "web_search": true,
        "timeout_secs": 900,
        "max_attempts": null
      },
      "output_contract": null,
      "output_json_schema": null,
      "command": null,
      "manual": null
    },
    "ux-research": {
      "mode": "agent",
      "agent_id": "default",
      "directive": "Produce a UX brief from requirements and user flows. Identify key screens, interactions, and accessibility constraints.",
      "runtime": null,
      "output_contract": null,
      "output_json_schema": null,
      "command": null,
      "manual": null
    },
    "wireframe": {
      "mode": "agent",
      "agent_id": "default",
      "directive": "Create concrete UI mockups/wireframes in the repository under mockups/. Prefer production-like React-oriented layouts and realistic states.",
      "runtime": null,
      "output_contract": null,
      "output_json_schema": null,
      "command": null,
      "manual": null
    },
    "mockup-review": {
      "mode": "agent",
      "agent_id": "default",
      "directive": "Review mockups against linked requirements. Resolve mismatches, improve usability, and ensure acceptance criteria traceability.",
      "runtime": null,
      "output_contract": null,
      "output_json_schema": null,
      "command": null,
      "manual": null
    },
    "implementation": {
      "mode": "agent",
      "agent_id": "swe",
      "directive": "Implement production-quality code for this task. Keep changes focused and executable.",
      "runtime": null,
      "capabilities": {
        "writes_files": true,
        "requires_commit": true,
        "enforce_product_changes": true
      },
      "output_contract": {
        "kind": "implementation_result",
        "required_fields": [
          "commit_message"
        ]
      },
      "output_json_schema": {
        "type": "object",
        "required": [
          "kind",
          "commit_message"
        ],
        "properties": {
          "kind": {
            "const": "implementation_result"
          },
          "commit_message": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      },
      "decision_contract": {
        "required_evidence": ["files_modified"],
        "min_confidence": 0.7,
        "max_risk": "medium",
        "allow_missing_decision": true
      },
      "command": null,
      "manual": null
    },
    "code-review": {
      "mode": "agent",
      "agent_id": "swe",
      "directive": "Review the implementation for defects, edge cases, and maintainability issues. Do NOT make changes yourself. If issues are found, set verdict to rework and provide an exact spec of what must be fixed in the reason field. Only advance if the code is production-ready as-is.",
      "runtime": null,
      "output_contract": null,
      "output_json_schema": null,
      "decision_contract": {
        "required_evidence": ["code_review_clean"],
        "min_confidence": 0.7,
        "max_risk": "medium",
        "allow_missing_decision": true
      },
      "command": null,
      "manual": null
    },
    "testing": {
      "mode": "agent",
      "agent_id": "swe",
      "directive": "Validate the implementation by reading tests and running the test suite. Do NOT write or modify code yourself. If tests fail or coverage gaps exist, set verdict to rework and provide an exact spec of what tests must be added or fixed. Only advance if all tests pass and coverage is adequate.",
      "runtime": null,
      "output_contract": null,
      "output_json_schema": null,
      "decision_contract": {
        "required_evidence": ["tests_passed"],
        "min_confidence": 0.8,
        "max_risk": "medium",
        "allow_missing_decision": true
      },
      "command": null,
      "manual": null
    }
  }
