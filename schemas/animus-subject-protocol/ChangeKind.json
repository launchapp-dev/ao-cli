{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChangeKind",
  "description": "Categorization of a subject change event.",
  "oneOf": [
    {
      "description": "Subject was newly created upstream.",
      "type": "string",
      "const": "created"
    },
    {
      "description": "Subject was updated (any field).",
      "type": "string",
      "const": "updated"
    },
    {
      "description": "Subject's normalized status transitioned.",
      "type": "string",
      "const": "status-changed"
    },
    {
      "description": "Subject was deleted upstream.",
      "type": "string",
      "const": "deleted"
    }
  ]
}
