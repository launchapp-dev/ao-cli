{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CustomFieldKind",
  "description": "The type of a custom field.",
  "oneOf": [
    {
      "description": "Free-form string.",
      "type": "string",
      "const": "string"
    },
    {
      "description": "Numeric (integer or float).",
      "type": "string",
      "const": "number"
    },
    {
      "description": "Boolean.",
      "type": "string",
      "const": "bool"
    },
    {
      "description": "Enumerated string; allowed values in [`CustomFieldSpec::values`].",
      "type": "string",
      "const": "enum"
    },
    {
      "description": "Date/time (ISO 8601).",
      "type": "string",
      "const": "date"
    }
  ]
}
