{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CustomFieldSpec",
  "description": "Description of one custom field a backend exposes.",
  "type": "object",
  "properties": {
    "key": {
      "description": "Field key as it appears in [`Subject::custom`].",
      "type": "string"
    },
    "type": {
      "description": "Field type.",
      "$ref": "#/$defs/CustomFieldKind"
    },
    "values": {
      "description": "For [`CustomFieldKind::Enum`] fields, the enumerated values.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "key",
    "type"
  ],
  "$defs": {
    "CustomFieldKind": {
      "description": "The type of a custom field.",
      "oneOf": [
        {
          "description": "Free-form string.",
          "type": "string",
          "const": "string"
        },
        {
          "description": "Numeric (integer or float).",
          "type": "string",
          "const": "number"
        },
        {
          "description": "Boolean.",
          "type": "string",
          "const": "bool"
        },
        {
          "description": "Enumerated string; allowed values in [`CustomFieldSpec::values`].",
          "type": "string",
          "const": "enum"
        },
        {
          "description": "Date/time (ISO 8601).",
          "type": "string",
          "const": "date"
        }
      ]
    }
  }
}
