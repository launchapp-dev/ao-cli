{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SubjectSchema",
  "description": "Capability declaration returned by `subject/schema`.\n\nThe daemon uses this to adapt behavior without runtime guessing — for\nexample, to skip `subject/watch` for polling-only backends, or to\npre-populate a UI with the subject's available custom-field values.",
  "type": "object",
  "properties": {
    "custom_fields": {
      "description": "Custom field declarations.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/CustomFieldSpec"
      }
    },
    "kinds": {
      "description": "Subject kinds this backend produces.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "native_status_values": {
      "description": "Native (pre-mapping) status values the backend uses upstream. Useful\nfor documenting `status_map` entries in workflow YAML.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status_values": {
      "description": "Normalized status values this backend can emit.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/SubjectStatus"
      }
    },
    "supports_create": {
      "description": "Whether the backend can create new subjects (reserved for v0.4.x).",
      "type": "boolean"
    },
    "supports_pagination": {
      "description": "Whether `subject/list` honors `cursor`.",
      "type": "boolean"
    },
    "supports_watch": {
      "description": "Whether `subject/watch` is implemented.",
      "type": "boolean"
    }
  },
  "required": [
    "kinds",
    "status_values",
    "supports_watch",
    "supports_create",
    "supports_pagination"
  ],
  "$defs": {
    "CustomFieldKind": {
      "description": "The type of a custom field.",
      "oneOf": [
        {
          "description": "Free-form string.",
          "type": "string",
          "const": "string"
        },
        {
          "description": "Numeric (integer or float).",
          "type": "string",
          "const": "number"
        },
        {
          "description": "Boolean.",
          "type": "string",
          "const": "bool"
        },
        {
          "description": "Enumerated string; allowed values in [`CustomFieldSpec::values`].",
          "type": "string",
          "const": "enum"
        },
        {
          "description": "Date/time (ISO 8601).",
          "type": "string",
          "const": "date"
        }
      ]
    },
    "CustomFieldSpec": {
      "description": "Description of one custom field a backend exposes.",
      "type": "object",
      "properties": {
        "key": {
          "description": "Field key as it appears in [`Subject::custom`].",
          "type": "string"
        },
        "type": {
          "description": "Field type.",
          "$ref": "#/$defs/CustomFieldKind"
        },
        "values": {
          "description": "For [`CustomFieldKind::Enum`] fields, the enumerated values.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "key",
        "type"
      ]
    },
    "SubjectStatus": {
      "description": "Normalized cross-backend subject status.\n\nBackend-native states (`\"Backlog\"`, `\"In Review\"`, `\"Won't Fix\"`, ...) map\ninto one of these five via the `status_map` declared per-subject in\nworkflow YAML. The mapping lives in configuration, not code, so adding a\nnew backend never requires extending this enum.",
      "oneOf": [
        {
          "description": "Eligible for dispatch.",
          "type": "string",
          "const": "ready"
        },
        {
          "description": "Currently being worked by a workflow run (or by a human, in the\nupstream system).",
          "type": "string",
          "const": "in-progress"
        },
        {
          "description": "Cannot proceed; awaiting unblock.",
          "type": "string",
          "const": "blocked"
        },
        {
          "description": "Successfully completed.",
          "type": "string",
          "const": "done"
        },
        {
          "description": "Abandoned without completion.",
          "type": "string",
          "const": "cancelled"
        }
      ]
    }
  }
}
